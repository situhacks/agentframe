# === Secrets ===
.env
.env.local

# === Operator content (PII / private to the operator running this fork) ===
# All operator context is private by default, except the shared metadata shapes
# and operator examples.
library/context/*
!library/context/_meta/
!library/context/operator.example/

# Operator builder backlogs (keeps personal system fixes out of forks)
system/builder-backlog*.md

# === Operator projects ===
# All projects are private by default.
workspace/projects/*

# === Operator research ===
workspace/research/

# === Runtime / generated state ===
system/logs/
system/audit/*.db
system/audit/*.db-shm
system/audit/*.db-wal

# === Browser harness runtime ===
system/browser/runs/
system/browser/workflows/**/runs/
system/browser/cache/
system/browser/local/
system/browser/node_modules/
system/browser/dist/
system/browser/.env

# === Open Design local runtime / build artifacts ===
# Upstream source/.gitignore is canonical; these top-level guards prevent
# accidental staging from tools that bypass nested ignore rules.
system/skills/open-design/source/node_modules/
system/skills/open-design/source/.od/
system/skills/open-design/source/.od-e2e/
system/skills/open-design/source/dist/
system/skills/open-design/source/out/
system/skills/open-design/source/.next/
system/skills/open-design/source/.next-*/
system/skills/open-design/source/.tmp/
system/skills/open-design/source/test-results/
system/skills/open-design/source/playwright-report/
system/skills/open-design/source/e2e/.od-data/
system/skills/open-design/source/e2e/reports/

# === Open Design — operator content added under the source subtree ===
# Match every subdirectory under design-systems/ and skills/. Git only
# applies gitignore to UNTRACKED paths, so upstream-shipped design systems
# and skills (already tracked) stay tracked. Anything new the operator adds
# here is campaign- or operator-specific and stays local.
system/skills/open-design/source/design-systems/*/
system/skills/open-design/source/skills/*/

# === Scratch / scratchpad directories anywhere in the tree ===
**/_scratch/

# === Exported deliverable binaries inside campaigns ===
# Keep authoring sources in markdown; export binaries are regenerable.
workspace/**/*.docx
workspace/**/*.pptx

# === OS / editor cruft ===
Thumbs.db
.DS_Store
*.swp

# === Python bytecode caches ===
__pycache__/
*.pyc
*.pyo

# === Editor metadata ===
.vscode/
.idea/

# === Claude Code operator-local config ===
# Personal hook scripts and local settings (e.g. git-push-guard) stay on the
# operator's machine. If a settings.json file ever ships as a repo default,
# un-ignore it explicitly.
.claude/
