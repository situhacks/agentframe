.env
.env.local

# === Operator content (PII / private to the operator running this fork) ===
# library/context/operator/ holds positioning, voice, design-language, profile.
# Forkers seed it from library/context/operator.example/ (committed) — see README/SETUP.
library/context/operator/

# === Operator campaigns + research (real work product, often pre-publication) ===
workspace/campaigns/
workspace/research/

# === Operator career / personal artifacts ===
career/

# === System logs (operator paths, real campaign slugs, real decisions) ===
system/logs/audit-log.md
system/logs/smoke-test-runs/
system/audit/agentframe.db
system/audit/agentframe.db-shm
system/audit/agentframe.db-wal
system/audit/marketingos.db
system/audit/marketingos.db-shm
system/audit/marketingos.db-wal

# === Browser harness runtime ===
system/browser/runs/
system/browser/workflows/*/runs/
system/browser/workflows/**/runs/
system/browser/cache/
system/browser/local/
system/browser/node_modules/
system/browser/dist/
system/browser/.env

# === Open Design local runtime/build artifacts (belt-and-suspenders) ===
# Upstream source/.gitignore is canonical; these top-level guards prevent
# accidental staging from tools that bypass nested ignore rules.
system/skills/open-design/source/node_modules/
system/skills/open-design/source/.od/
system/skills/open-design/source/.od-e2e/
system/skills/open-design/source/dist/
system/skills/open-design/source/out/
system/skills/open-design/source/.next/
system/skills/open-design/source/.next-*/
system/skills/open-design/source/.tmp/
system/skills/open-design/source/test-results/
system/skills/open-design/source/playwright-report/
system/skills/open-design/source/e2e/.od-data/
system/skills/open-design/source/e2e/reports/

# === Real export examples (real campaign data) ===
system/exports/examples/

# === Scratch / scratchpad directories anywhere in tree ===
**/_scratch/

# === Exported deliverable binaries ===
workspace/**/*.docx
workspace/**/*.pptx

# === OS / editor cruft ===
Thumbs.db
.DS_Store
*.swp

# === Python bytecode caches ===
__pycache__/
*.pyc
*.pyo

# === Editor metadata ===
.vscode/
.idea/
